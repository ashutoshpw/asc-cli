# App Store Connect API credentials
# Obtain these from App Store Connect > Users and Access > Integrations > API Keys

# Key ID (required)
ASC_KEY_ID=

# Issuer ID (required)
ASC_ISSUER_ID=

# Private key - provide one of the three options below:
ASC_PRIVATE_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8   # Path to .p8 file
# ASC_PRIVATE_KEY=                                      # Inline PEM content
# ASC_PRIVATE_KEY_B64=                                  # Base64-encoded PEM content

# Vendor number (required for sales/finance reports)
# ASC_VENDOR_NUMBER=

# Default app ID (optional, avoids passing --app-id on every command)
# ASC_APP_ID=

# Timeouts (optional, supports "30s", "2m", "1500ms")
# ASC_TIMEOUT=30s
# ASC_UPLOAD_TIMEOUT=120s

# Retry behaviour (optional)
# ASC_MAX_RETRIES=3
# ASC_BASE_DELAY=1000
# ASC_MAX_DELAY=30000

# Behaviour flags (optional, set to "true" or "1" to enable)
# ASC_DEBUG=true              # Enable debug logging (set to "api" for HTTP-level logging)
# ASC_RETRY_LOG=true          # Log retry attempts
# ASC_NO_UPDATE=true          # Disable update checks
# ASC_BYPASS_KEYCHAIN=true    # Skip macOS Keychain lookup
# ASC_STRICT_AUTH=true        # Fail if credentials are not fully resolved
